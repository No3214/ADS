# === Kozbeyli Konagi — Reklam ortam degiskenleri (v3) =======================
# Bu dosyayi .env olarak kopyalayin ve doldurun. .env GIT'E GIRMEZ (.gitignore).
# TOKEN / SECRET / REFRESH TOKEN'i ASLA sohbete veya GitHub'a yazmayin.

# --- Olcum kimlikleri (bilinen) --------------------------------------------
GA4_MEASUREMENT_ID=G-V3R66C3MEF
GOOGLE_ADS_TAG_ID=AW-800024713
META_PIXEL_ID=1781546559309505
META_BUSINESS_ID=604201716594111
GTM_CONTAINER_ID=                      # Iki adaydan canli olani (docs/02 ile belirleyin)

# --- Reklam hesabi kimlikleri (EKSIK — doldurun) ---------------------------
META_AD_ACCOUNT_ID=act_REPLACE_ME       # Ads Manager > hesap secici
GOOGLE_ADS_CUSTOMER_ID=XXX-XXX-XXXX     # 10 hane (tireli yazabilirsiniz)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=           # MCC kullaniyorsaniz

# --- Google Ads MCP (RESMI, okuma) -----------------------------------------
GOOGLE_PROJECT_ID=replace-me
GOOGLE_ADS_DEVELOPER_TOKEN=replace-me   # En az Explorer erisimi (uretim sorgusu icin)
GOOGLE_ADS_MCP_OAUTH_CLIENT_ID=replace-me
GOOGLE_ADS_MCP_OAUTH_CLIENT_SECRET=replace-me
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-oauth.json

# --- Butce sinirlari (guardrails.py okur) ----------------------------------
GOOGLE_MONTHLY_BUDGET_TRY=15000
META_MONTHLY_BUDGET_TRY=15000
GOOGLE_AVG_DAILY_BUDGET_TRY=493
META_DAILY_BUDGET_TRY=500

# --- Yazma kapisi ----------------------------------------------------------
# false = gercek yazma kapali (yalnizca dry-run/onizleme). Tracking dogrulanip
# allowlist dolmadan true YAPMAYIN.
ADS_WRITES_ENABLED=false
